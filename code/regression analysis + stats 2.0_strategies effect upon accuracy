        def mahalanobis_distance(df, cols):
            cov_matrix = np.cov(df[cols].T)
            inv_cov_matrix = np.linalg.inv(cov_matrix)
            mean_vals = df[cols].mean().values
            return df[cols].apply(lambda row: mahalanobis(row.values, mean_vals, inv_cov_matrix), axis=1)

