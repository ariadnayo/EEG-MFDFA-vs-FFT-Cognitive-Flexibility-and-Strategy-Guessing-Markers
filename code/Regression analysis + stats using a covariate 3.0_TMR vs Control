        z_order = sorted(df_statistics[z_var].unique())
        palette_dict = dict(zip(z_order, my_palette))

        def mahalanobis_distance(df, cols):
            cov_matrix = np.cov(df[cols].T)
            inv_cov_matrix = np.linalg.inv(cov_matrix)
            mean_vals = df[cols].mean().values
            return df[cols].apply(lambda row: mahalanobis(row.values, mean_vals, inv_cov_matrix), axis=1)

        models = {
            "OLS": {"model": LinearRegression(), "style": {"color": "red", "linestyle": "-", "label": "OLS"}},
            "RANSAC": {"model": RANSACRegressor(), "style": {"color": "red", "linestyle": "dotted", "label": "RANSAC"}},
            "Theil-Sen": {"model": TheilSenRegressor(), "style": {"color": "red", "linestyle": "dashed", "label": "Theil-Sen"}}
        }

        fig, axes = plt.subplots(1, 3, figsize=(18, 5), sharey=True)

        for ax, (name, config) in zip(axes, models.items()):
